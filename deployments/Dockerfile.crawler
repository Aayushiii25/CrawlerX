# Multi-stage build for CrawlerX Crawler Node

# Stage 1: Build
FROM golang:1.22-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o crawler ./cmd/crawler

# Stage 2: Run
FROM alpine:3.19

RUN apk --no-cache add ca-certificates
WORKDIR /app
RUN mkdir -p /app/data

COPY --from=builder /build/crawler .

ENTRYPOINT ["./crawler"]

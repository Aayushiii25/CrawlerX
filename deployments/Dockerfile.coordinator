# Multi-stage build for CrawlerX Coordinator
# Final image is ~15MB Alpine-based

# Stage 1: Build
FROM golang:1.22-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o coordinator ./cmd/coordinator

# Stage 2: Run
FROM alpine:3.19

RUN apk --no-cache add ca-certificates wget
WORKDIR /app

COPY --from=builder /build/coordinator .

EXPOSE 8080

ENTRYPOINT ["./coordinator"]

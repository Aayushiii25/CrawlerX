# CrawlerX Environment Configuration
# Copy to .env and modify as needed

# --- Redis ---
CRAWLERX_REDIS_ADDR=localhost:6379
CRAWLERX_REDIS_PASSWORD=
CRAWLERX_REDIS_DB=0

# --- Coordinator ---
CRAWLERX_COORDINATOR_ADDR=http://localhost:8080
CRAWLERX_COORDINATOR_PORT=8080
CRAWLERX_HEARTBEAT_INTERVAL=10s
CRAWLERX_HEARTBEAT_TIMEOUT=30s
CRAWLERX_METRICS_CACHE_TTL=1s
CRAWLERX_CORS_ORIGINS=http://localhost:3000

# --- Crawler Node ---
# Leave CRAWLERX_NODE_ID empty to auto-generate from hostname+PID
CRAWLERX_NODE_ID=
CRAWLERX_WORKER_COUNT=10
CRAWLERX_MAX_CRAWL_DEPTH=5
CRAWLERX_MAX_RETRIES=3
CRAWLERX_REQUEST_TIMEOUT=30s
CRAWLERX_USER_AGENT=CrawlerX/1.0 (+https://github.com/crawlerx/crawlerx)
CRAWLERX_MAX_REDIRECTS=5
CRAWLERX_ROBOTS_CACHE_TTL=24h

# --- Rate Limiting ---
CRAWLERX_DEFAULT_RATE_LIMIT=1.0
CRAWLERX_RATE_LIMIT_BURST=3

# --- Bloom Filter ---
CRAWLERX_BLOOM_EXPECTED_ITEMS=10000000
CRAWLERX_BLOOM_FP_RATE=0.01

# --- Hash Ring ---
CRAWLERX_VIRTUAL_NODES=150

# --- Distributed Lock ---
CRAWLERX_LOCK_TTL=60s

# --- Queue ---
CRAWLERX_QUEUE_BATCH_SIZE=10
CRAWLERX_RETRY_BASE_DELAY=5s
CRAWLERX_DLQ_MAX_SIZE=100000

# --- Storage ---
CRAWLERX_DATA_DIR=./data

# --- Dashboard ---
CRAWLERX_DASHBOARD_PORT=3000

# --- AI Scoring (optional) ---
# Supported providers: openai, gemini, anthropic
CRAWLERX_LLM_PROVIDER=
CRAWLERX_LLM_API_KEY=
CRAWLERX_LLM_MODEL=

# --- Logging ---
CRAWLERX_LOG_LEVEL=info

# --- Event Bus ---
CRAWLERX_EVENT_CHANNEL_BUFFER=1000
